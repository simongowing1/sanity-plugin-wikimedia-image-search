{
  "name": "sanity-plugin-wikimedia-image-search",
  "version": "1.0.0",
  "description": "Search Wikimedia Commons for freely-licensed images and insert them into Sanity Studio.",
  "keywords": [
    "sanity",
    "sanity-plugin",
    "wikimedia",
    "wikimedia-commons",
    "image-search"
  ],
  "sanityPlugin": {
    "verifyPackage": {
      "tsc": false,
      "sanityV2Json": false
    }
  },
  "homepage": "https://github.com/simongowing1/sanity-plugin-wikimedia-image-search#readme",
  "bugs": {
    "url": "https://github.com/simongowing1/sanity-plugin-wikimedia-image-search/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/simongowing1/sanity-plugin-wikimedia-image-search.git"
  },
  "license": "MIT",
  "author": "Simon Gowing",
  "sideEffects": false,
  "type": "commonjs",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "plugin-kit verify-package --silent && pkg-utils build --strict --check --clean",
    "format": "prettier --write --cache --ignore-unknown .",
    "link-watch": "plugin-kit link-watch",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "watch": "pkg-utils watch --strict",
    "prepare": "husky"
  },
  "dependencies": {
    "@sanity/icons": "^3.7.4",
    "@sanity/ui": "^3.1.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@sanity/pkg-utils": "^7.1.1",
    "@sanity/plugin-kit": "^4.0.19",
    "@sanity/semantic-release-preset": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-config-sanity": "^7.1.4",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "prettier-plugin-packagejson": "^2.5.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sanity": "^5.0.0",
    "styled-components": "^6.1.16",
    "ts-jest": "^29.4.6",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "sanity": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.2",
  "browserslist": "extends @sanity/browserslist-config"
}
